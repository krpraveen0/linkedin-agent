{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aep/schemas/topic-signal.schema.json",
  "title": "TopicSignal",
  "type": "object",
  "required": ["id", "captured_at", "source", "topic", "signal_type", "evidence_url"],
  "properties": {
    "id": { "type": "string" },
    "captured_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "topic": { "type": "string" },
    "signal_type": { "type": "string", "enum": ["release", "trend", "discussion", "benchmark", "incident"] },
    "summary": { "type": "string" },
    "evidence_url": { "type": "string", "format": "uri" },
    "official_source": { "type": "boolean", "default": false }
  },
  "additionalProperties": false
}
