{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aep/schemas/ranked-topic.schema.json",
  "title": "RankedTopic",
  "type": "object",
  "required": ["topic", "scores", "overall_score", "ranked_at"],
  "properties": {
    "topic": { "type": "string" },
    "ranked_at": { "type": "string", "format": "date-time" },
    "scores": {
      "type": "object",
      "required": ["freshness", "relevance", "practicality", "novelty"],
      "properties": {
        "freshness": { "type": "number", "minimum": 0, "maximum": 100 },
        "relevance": { "type": "number", "minimum": 0, "maximum": 100 },
        "practicality": { "type": "number", "minimum": 0, "maximum": 100 },
        "novelty": {
          "type": "number", "minimum": 0, "maximum": 100,
          "description": "100 minus similarity to the closest already-published topic — how not-a-repeat this is."
        }
      },
      "additionalProperties": false
    },
    "overall_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "references": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "similarity_to_existing": {
      "type": "number", "minimum": 0, "maximum": 1,
      "description": "Highest Jaccard similarity found against any already-published articles/**/research-bundle.json topic."
    },
    "most_similar_existing": { "type": ["string", "null"] },
    "most_similar_existing_path": { "type": ["string", "null"] },
    "excluded_reason": {
      "type": "string",
      "description": "Present only on entries returned in ranked-topics.json's excluded_duplicates list."
    }
  },
  "additionalProperties": false
}
