{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aep/schemas/research-bundle.schema.json",
  "title": "ResearchBundle",
  "type": "object",
  "required": ["topic", "objective", "official_references", "claims"],
  "properties": {
    "topic": { "type": "string" },
    "objective": { "type": "string" },
    "official_references": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "minItems": 1
    },
    "supporting_references": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "competitive_scan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_url", "differentiation"],
        "properties": {
          "source_url": { "type": "string", "format": "uri" },
          "differentiation": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statement", "reference_urls"],
        "properties": {
          "statement": { "type": "string" },
          "reference_urls": {
            "type": "array",
            "items": { "type": "string", "format": "uri" },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
